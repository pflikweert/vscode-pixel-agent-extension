{
  "name": "pixel-copilot-agent",
  "displayName": "Pixel Copilot Agent",
  "description": "A starter extension with a pixel-style agent panel and Copilot Chat participant.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.99.0"
  },
  "enabledApiProposals": [],
  "categories": [
    "Other",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelAccess",
    "onChatParticipant:pixel-copilot-agent.pixel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixelAgent.openPanel",
        "title": "Pixel Agent: Open Panel"
      },
      {
        "command": "pixelAgent.emitTestEvents",
        "title": "Pixel Agent: Emit Test Events"
      }
    ],
    "chatParticipants": [
      {
        "id": "pixel-copilot-agent.pixel",
        "name": "pixel",
        "fullName": "Pixel Agent",
        "description": "A playful coding sidekick that can reason over your workspace and show visual state.",
        "isSticky": true,
        "commands": [
          {
            "name": "show",
            "description": "Open the pixel visualizer panel"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Pixel Agent",
      "properties": {
        "pixelAgent.copilotExport.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable exporting Copilot prompt/response and editor context to an external endpoint."
        },
        "pixelAgent.copilotExport.endpoint": {
          "type": "string",
          "default": "",
          "description": "HTTP endpoint that receives Copilot interaction payloads (POST JSON)."
        },
        "pixelAgent.copilotExport.timeoutMs": {
          "type": "number",
          "default": 4500,
          "minimum": 500,
          "maximum": 60000,
          "description": "Timeout in milliseconds for exporting Copilot payloads."
        },
        "pixelAgent.copilotExport.includeOpenFiles": {
          "type": "boolean",
          "default": true,
          "description": "Include a small list of open files in the export payload context."
        },
        "pixelAgent.copilotExport.redactSensitiveData": {
          "type": "boolean",
          "default": true,
          "description": "Redact common secret-like key/value pairs before export."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p ./",
    "build:webview": "vite build --config webview-ui/vite.config.ts",
    "watch": "npm run watch:extension",
    "watch:extension": "tsc -w -p ./ --preserveWatchOutput",
    "dev:webview": "vite --config webview-ui/vite.config.ts",
    "lint": "eslint \"src/**/*.ts\" \"webview-ui/src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.3.0",
    "globals": "^17.4.0",
    "typescript": "^5.4.5",
    "vite": "^7.3.1"
  }
}
